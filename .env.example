# Supabase — copy to .env and fill in from your Supabase project settings.
# Project Settings → API
SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"

# Service role key. SECRET — server-side only. Never expose to the browser or
# commit it. Used by the Netlify Functions to write to the database.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Random string used to hash visitor IPs before storage (privacy-friendly).
# Generate one with: openssl rand -hex 32
TRACKING_IP_SALT="change-me-to-a-long-random-string"

# Optional: lock the API to your own origin (defaults to "*").
# ALLOWED_ORIGIN="https://www.charlotteefoil.com"

# Password for the /admin analytics dashboard. Required to view analytics.
# Choose a long, private value. Generate one with: openssl rand -hex 24
ADMIN_PASSWORD="set-a-strong-admin-password"

# Email via Amazon SES — powers reservation notifications AND bulk campaigns.
# Create an IAM user with ses:SendEmail permission (do NOT use root keys).
# Note: names are SES_-prefixed because Lambda reserves AWS_* variables.
SES_REGION="us-east-1"
SES_ACCESS_KEY_ID=""
SES_SECRET_ACCESS_KEY=""
# Verified sender identity/domain in SES.
SES_FROM_EMAIL="CharlotteEfoil <reservations@charlotteefoil.com>"

# Where reservation notifications are routed.
NOTIFY_EMAIL="hello@charlotteefoil.com"

# CAN-SPAM footer for bulk campaigns (physical mailing address recommended).
MAIL_FOOTER_ADDRESS="CharlotteEfoil · Charlotte, NC"

# Public site URL (used to build unsubscribe links). Optional; auto-detected.
# SITE_URL="https://www.charlotteefoil.com"
